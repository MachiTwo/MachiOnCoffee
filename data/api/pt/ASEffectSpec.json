{
    "name": "ASEffectSpec",
    "inherits": "RefCounted",
    "brief_description": "Runtime instance of an effect.",
    "description": "[ASEffectSpec] represents an active effect. It stores the remaining duration and calculated magnitudes.",
    "properties": [
        {
            "name": "hit_position",
            "type": "Variant",
            "setter": "set_hit_position",
            "getter": "get_hit_position",
            "default": "null",
            "description": "Impact position (Vector2 or Vector3) usually associated with a collision query."
        },
        {
            "name": "target_node",
            "type": "Object",
            "setter": "set_target_node",
            "getter": "get_target_node",
            "default": "",
            "description": "The target Object/Node that the effect is applied to or interacting with."
        }
    ],
    "methods": [
        {
            "name": "get_duration_remaining",
            "qualifiers": "const",
            "description": "Returns time left before effect ends.",
            "return_type": "float",
            "params": []
        },
        {
            "name": "get_effect",
            "qualifiers": "const",
            "description": "Returns the effect resource definition.",
            "return_type": "ASEffect",
            "params": []
        },
        {
            "name": "get_level",
            "qualifiers": "const",
            "description": "Returns the power level of the effect instance.",
            "return_type": "float",
            "params": []
        },
        {
            "name": "get_magnitude",
            "qualifiers": "const",
            "description": "Returns the calculated modifier value for an attribute.",
            "return_type": "float",
            "params": [
                {
                    "name": "name",
                    "type": "StringName",
                    "default": ""
                }
            ]
        },
        {
            "name": "get_period_timer",
            "qualifiers": "const",
            "description": "Returns the time remaining until the next periodic tick.",
            "return_type": "float",
            "params": []
        },
        {
            "name": "get_source_attribute_value",
            "qualifiers": "const",
            "description": "Returns the value of an attribute on the source component.",
            "return_type": "float",
            "params": [
                {
                    "name": "attribute",
                    "type": "StringName",
                    "default": ""
                }
            ]
        },
        {
            "name": "get_source_component",
            "qualifiers": "const",
            "description": "Returns the ASC that applied this effect.",
            "return_type": "ASComponent",
            "params": []
        },
        {
            "name": "get_stack_count",
            "qualifiers": "const",
            "description": "Returns the current number of stacks for this effect.",
            "return_type": "int",
            "params": []
        },
        {
            "name": "get_target_attribute_value",
            "qualifiers": "const",
            "description": "Returns the value of an attribute on the target component.",
            "return_type": "float",
            "params": [
                {
                    "name": "attribute",
                    "type": "StringName",
                    "default": ""
                }
            ]
        },
        {
            "name": "get_target_component",
            "qualifiers": "const",
            "description": "Returns the destination component where the effect is applied.",
            "return_type": "ASComponent",
            "params": []
        },
        {
            "name": "get_total_duration",
            "qualifiers": "const",
            "description": "Returns the initial calculated duration.",
            "return_type": "float",
            "params": []
        },
        {
            "name": "init",
            "qualifiers": "",
            "description": "Initializes the effect specification with a definition and level.",
            "return_type": "void",
            "params": [
                {
                    "name": "effect",
                    "type": "ASEffect",
                    "default": ""
                },
                {
                    "name": "level",
                    "type": "float",
                    "default": "1.0"
                }
            ]
        },
        {
            "name": "set_duration_remaining",
            "qualifiers": "",
            "description": "Sets the remaining time for the effect.",
            "return_type": "void",
            "params": [
                {
                    "name": "value",
                    "type": "float",
                    "default": ""
                }
            ]
        },
        {
            "name": "set_level",
            "qualifiers": "",
            "description": "Sets the power level of this instance.",
            "return_type": "void",
            "params": [
                {
                    "name": "level",
                    "type": "float",
                    "default": ""
                }
            ]
        },
        {
            "name": "set_magnitude",
            "qualifiers": "",
            "description": "Manually sets the calculated magnitude for an attribute.",
            "return_type": "void",
            "params": [
                {
                    "name": "name",
                    "type": "StringName",
                    "default": ""
                },
                {
                    "name": "value",
                    "type": "float",
                    "default": ""
                }
            ]
        },
        {
            "name": "set_period_timer",
            "qualifiers": "",
            "description": "Sets the internal timer for the next periodic tick.",
            "return_type": "void",
            "params": [
                {
                    "name": "timer",
                    "type": "float",
                    "default": ""
                }
            ]
        },
        {
            "name": "set_stack_count",
            "qualifiers": "",
            "description": "Sets the number of stacks.",
            "return_type": "void",
            "params": [
                {
                    "name": "count",
                    "type": "int",
                    "default": ""
                }
            ]
        },
        {
            "name": "set_total_duration",
            "qualifiers": "",
            "description": "Sets the total duration.",
            "return_type": "void",
            "params": [
                {
                    "name": "value",
                    "type": "float",
                    "default": ""
                }
            ]
        }
    ],
    "signals": [],
    "constants": []
}