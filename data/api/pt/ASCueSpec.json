    "properties": [
        {
            "name": "cue",
            "type": "ASCue",
            "setter": "set_cue",
            "getter": "get_cue",
            "default": "",
            "description": "The definition resource."
        },
        {
            "name": "effect_spec",
            "type": "ASEffectSpec",
            "setter": "set_effect_spec",
            "getter": "get_effect_spec",
            "default": "",
            "description": "The associated effect specification that triggered this cue."
        },
        {
            "name": "extra_data",
            "type": "Dictionary",
            "setter": "set_extra_data",
            "getter": "get_extra_data",
            "default": "{}",
            "description": "Any extra data passed to the cue."
        },
        {
            "name": "hit_position",
            "type": "Variant",
            "setter": "set_hit_position",
            "getter": "get_hit_position",
            "default": "null",
